# Swift Package Manager build products and the assembled .app bundle.
# Package.resolved IS checked in intentionally — pinning transitive deps
# (swift-nio, async-http-client, Yams) makes builds reproducible.
.build/
build/
DerivedData/
*.xcodeproj

# Icon workbench — the intermediate PNGs and generated iconset are big
# and easy to reproduce with bundle/build-icon.sh. AppIcon.icns is
# checked in so a normal build doesn't need ImageMagick+qlmanage.
bundle/icon-src/logo-1024.png
bundle/icon-src/logo-inset.png
bundle/icon-src/mask.png
bundle/icon-src/framed-1024.png
bundle/icon-src/AppIcon.iconset/
